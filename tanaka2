task.spawn(function()
    repeat task.wait() until game:IsLoaded()

    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local Camera = workspace.CurrentCamera

    local LP = Players.LocalPlayer
    local espObjects = {}
    local speedThreshold = 500

    -- 線を作成する関数
    local function createLine(adornee, color)
        local line = Instance.new("SelectionBox")
        line.Adornee = adornee
        line.Color3 = color or Color3.fromRGB(255, 255, 255)
        line.Transparency = 0.5
        line.LineThickness = 0.1
        line.Parent = adornee
        return line
    end

    local function createESP(player)
        if player == LP then return end
        
        local char = player.Character
        if not char then return end
        
        -- 既存のESPを削除
        if espObjects[player] then
            for _, obj in pairs(espObjects[player]) do
                if obj then pcall(function() obj:Destroy() end) end
            end
            espObjects[player] = nil
        end
        
        local esp = {}
        
        -- 相手のキャラ全体に線
        local line = createLine(char, Color3.fromRGB(255, 255, 255))
        esp.Line = line
        
        -- 自分と相手を結ぶ線（別の方法）
        local connectionLine = Instance.new("SelectionBox")
        connectionLine.Adornee = char
        connectionLine.Color3 = Color3.fromRGB(255, 255, 255)
        connectionLine.Transparency = 0.3
        connectionLine.LineThickness = 0.05
        connectionLine.Parent = char
        
        esp.ConnectionLine = connectionLine
        
        espObjects[player] = esp
    end

    -- プレイヤーのキャラクターが変更された時の処理
    local function onCharacterAdded(player, char)
        task.wait(0.5)
        if player ~= LP then
            createESP(player)
        end
    end

    -- 速度チェックと色更新
    RunService.Heartbeat:Connect(function()
        local lpChar = LP.Character
        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
        
        for player, esp in pairs(espObjects) do
            local char = player.Character
            if not char then 
                -- キャラがなくなったらESPを削除
                if esp.Line then pcall(function() esp.Line:Destroy() end) end
                if esp.ConnectionLine then pcall(function() esp.ConnectionLine:Destroy() end) end
                espObjects[player] = nil
                continue
            end
            
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            
            local speed = root.AssemblyLinearVelocity.Magnitude
            
            local color
            if speed >= speedThreshold then
                color = Color3.fromRGB(255, 0, 0) -- 赤
            else
                color = Color3.fromRGB(255, 255, 255) -- 白
            end
            
            if esp.Line and esp.Line.Parent then
                esp.Line.Color3 = color
            end
            
            if esp.ConnectionLine and esp.ConnectionLine.Parent then
                esp.ConnectionLine.Color3 = color
            end
        end
    end)

    -- プレイヤー追加時
    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function(char)
            onCharacterAdded(player, char)
        end)
    end)

    -- 既存プレイヤー
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LP then
            if player.Character then
                createESP(player)
            end
            player.CharacterAdded:Connect(function(char)
                onCharacterAdded(player, char)
            end)
        end
    end
end)
